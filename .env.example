# LLM Configuration
# Options: ollama, huggingface, mock (defaults to ollama)
LLM_PROVIDER=mock

# Ollama model name (if provider is ollama)
OLLAMA_MODEL=llama3.1:8b

# Hugging Face Configuration (if provider is huggingface)
HF_API_TOKEN=
HF_MODEL=google/gemma-2-9b-it

# Database Configuration
DATABASE_URL=sqlite:///rag_logs.db

# RAG Settings
TOP_K=4
EMBEDDING_MODEL=all-MiniLM-L6-v2
